{"id":1,"name":"EV001","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":245,"indent":0,"parameters":[{"name":"City","volume":10,"pitch":70,"pan":0}]},{"code":241,"indent":0,"parameters":[{"name":"Deeper_loop_","volume":25,"pitch":100,"pan":0}]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["经法医鉴定，受害者胸口被利器刺穿致死。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["那几节车厢的监控都坏了，没有拍到被害的过程。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["以上是我们可以对你透露的信息。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["你是第一个发现尸体的人。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["在地铁站的监控录像中，你也是唯一一个走进3707附近"]},{"code":401,"indent":0,"parameters":["车厢的人。"]},{"code":101,"indent":0,"parameters":["Actor1",0,0,2]},{"code":401,"indent":0,"parameters":["我不认识那个人。"]},{"code":101,"indent":0,"parameters":["",0,0,1]},{"code":401,"indent":0,"parameters":["受害人金独子，男，二十八岁。"]},{"code":401,"indent":0,"parameters":["米诺软公司的合同员工。"]},{"code":401,"indent":0,"parameters":["于下班途中的地铁上被杀害。"]},{"code":230,"indent":0,"parameters":[60]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["你坐地铁原本计划去什么地方？"]},{"code":101,"indent":0,"parameters":["Actor1",0,0,2]},{"code":401,"indent":0,"parameters":["我约了人见面。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["什么人，有证据吗？"]},{"code":101,"indent":0,"parameters":["Actor1",0,0,2]},{"code":401,"indent":0,"parameters":["我的邮箱里有信息。"]},{"code":101,"indent":0,"parameters":["Actor1",0,0,2]},{"code":401,"indent":0,"parameters":["我委托了一名侦探调查事情。"]},{"code":401,"indent":0,"parameters":["他说自己有了调查结果，"]},{"code":401,"indent":0,"parameters":["约我在地铁站见面。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["调查什么？"]},{"code":101,"indent":0,"parameters":["Actor1",0,0,2]},{"code":401,"indent":0,"parameters":["这是我的隐私。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["......不管你隐瞒了什么，"]},{"code":401,"indent":0,"parameters":["你的邮箱中并没有相关的邮件。"]},{"code":250,"indent":0,"parameters":[{"name":"Paralyze1","volume":90,"pitch":120,"pan":0}]},{"code":231,"indent":0,"parameters":[1,"shenxunshi2",0,0,0,0,100,100,255,0]},{"code":230,"indent":0,"parameters":[30]},{"code":235,"indent":0,"parameters":[1]},{"code":101,"indent":0,"parameters":["Actor1",0,0,2]},{"code":401,"indent":0,"parameters":["......"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["警察看他的眼神愈发怀疑，"]},{"code":401,"indent":0,"parameters":["已经把他当成了穷凶极恶的杀人犯。"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["明明出门前才检查过邮箱。"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["那个侦探是骗子吗？"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["又是谁杀了金独子，并且把尸体留在没有人的地铁上？"]},{"code":101,"indent":0,"parameters":["Actor1",0,0,2]},{"code":401,"indent":0,"parameters":["不管怎么样，我不认识死者。"]},{"code":101,"indent":0,"parameters":["",0,0,1]},{"code":401,"indent":0,"parameters":["刘众赫，男，二十八岁，职业选手。"]},{"code":401,"indent":0,"parameters":["因为年龄原因而逐渐隐退，转而担任教练和游戏主播。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["你们的人际关系表面上没有任何交集。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["不过这并不能摆脱你的嫌疑。"]},{"code":102,"indent":0,"parameters":[["我没有杀他的动机。","我没有能够杀他的凶器。"],1,0,2,0]},{"code":402,"indent":0,"parameters":[0,"我没有杀他的动机。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["我们不排除你有随机杀人的可能。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["或者还有什么我们暂时未调查出来的原因。"]},{"code":101,"indent":1,"parameters":["Actor1",0,0,2]},{"code":401,"indent":1,"parameters":["我又不是疯了，"]},{"code":401,"indent":1,"parameters":["怎么可能在地铁上随机杀人？"]},{"code":101,"indent":1,"parameters":["",0,1,2]},{"code":401,"indent":1,"parameters":["刘众赫突然想起了自己不合时宜的愤怒。"]},{"code":101,"indent":1,"parameters":["",0,1,2]},{"code":401,"indent":1,"parameters":["他为什么而愤怒呢？"]},{"code":101,"indent":1,"parameters":["",0,1,2]},{"code":401,"indent":1,"parameters":["因为被卷入一起谋杀事件，还是因为.....?"]},{"code":101,"indent":1,"parameters":["Actor1",0,0,2]},{"code":401,"indent":1,"parameters":["......"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["无论如何，得先摆脱自己的嫌疑。"]},{"code":102,"indent":1,"parameters":[["我没有杀死他的凶器。"],1,0,2,0]},{"code":402,"indent":1,"parameters":[0,"我没有杀死他的凶器。"]},{"code":119,"indent":2,"parameters":["1"]},{"code":0,"indent":2,"parameters":[]},{"code":404,"indent":1,"parameters":[]},{"code":0,"indent":1,"parameters":[]},{"code":402,"indent":0,"parameters":[1,"我没有能够杀他的凶器。"]},{"code":118,"indent":1,"parameters":["1"]},{"code":101,"indent":1,"parameters":["",0,0,1]},{"code":401,"indent":1,"parameters":["受害人被发现时穿着白色风衣，和同事描述的日常穿着不符。"]},{"code":401,"indent":1,"parameters":["风衣背后有被刺穿的洞口，佐证胸口被凶器刺穿。"]},{"code":101,"indent":1,"parameters":["",0,0,1]},{"code":401,"indent":1,"parameters":["受害人为心脏破裂，失血过多而死。死因没有疑点。"]},{"code":101,"indent":1,"parameters":["",0,0,1]},{"code":401,"indent":1,"parameters":["死亡时间符合刘众赫是凶手的推论。"]},{"code":101,"indent":1,"parameters":["",0,0,1]},{"code":401,"indent":1,"parameters":["推测凶器是一把长剑，凶手必须有足够的力量才能干净利落地"]},{"code":401,"indent":1,"parameters":["刺穿死者的胸口，而不是被卡在肋骨中。"]},{"code":0,"indent":1,"parameters":[]},{"code":404,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["Actor1",0,0,2]},{"code":401,"indent":0,"parameters":["如果我带着一把剑走上地铁，"]},{"co